 433          float spl0703_get_temperature(void)
 434          {
 435   1          float fTCompensate;
 436   1          float fTsc;
 437   1        EA = 0;
 438   1          fTsc = spl07.i32rawTemperature / (float)spl07.i32kT;
 439   1          fTCompensate =  spl07_calib_param.c0 * 0.5 + spl07_calib_param.c1 * fTsc;
 440   1        EA = 1;
 441   1          return fTCompensate;
 442   1      }
