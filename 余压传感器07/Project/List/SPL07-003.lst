 458   1          qua2 = spl07_calib_param.c00+fPsc*(spl07_calib_param.c10+fPsc*(spl07_calib_param.c20+fPsc*(spl07_calib
             -_param.c30+spl07_calib_param.c40*fPsc)));
 459   1          qua3 = fTsc * (spl07_calib_param.c01+fPsc * (spl07_calib_param.c11 + fPsc *(spl07_calib_param.c21+fPsc
             -*spl07_calib_param.c31)));
 460   1          //qua3 = 0.9f *fTsc * fPsc * (spl07_calib_param.c11 + fPsc * spl07_calib_param.c21);
 461   1        
 462   1          fPCompensate = qua2+qua3;
 463   1          //fPCompensate = spl07_calib_param.c00 + fPsc * qua2 + 0.9f *fTsc  * spl07_calib_param.c01 + qua3;
 464   1          return fPCompensate;
