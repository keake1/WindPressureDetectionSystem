  81          /*************************************
  82          /*函数名称：I2C_ReadAbyte(void)
  83          /*函数功能：从I2C设备读一个字节
  84          /*输入参数：无
  85          /*返回值：      从I2C读取到的数据
  86          *************************************/
  87          u8 I2C_ReadAbyte(void)
  88          {
  89   1              u8 i,dat;
  90   1              i = 8;
  91   1              I2C_SDA = 1;
  92   1              do
  93   1              {
  94   2                      I2C_SCL = 1;
  95   2                      Wait();
  96   2                      dat <<= 1;
  97   2                      if(I2C_SDA)             dat++;
  98   2                      I2C_SCL  = 0;
  99   2                      Wait();
 100   2              }
 101   1              while(--i);
 102   1              return(dat);
 103   1      }
