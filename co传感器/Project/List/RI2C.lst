  24          /*输入参数：无
  25          /*返回值：      无
  26          *************************************/
  27          void I2C_Start(void)    //start the I2C, SDA High-to-low when SCL is high
  28          {
  29   1              I2C_SDA = 1;
  30   1              Wait();
  31   1              I2C_SCL = 1;
  32   1              Wait();
  33   1              I2C_SDA = 0;
  34   1              Wait();
  35   1              I2C_SCL = 0;
