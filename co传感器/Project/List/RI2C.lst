 159          void WriteNbyte(u8 addr, u8 *p, u8 num)  /*  WordAddress,First Data Address,Byte lenth   */
 160          {
 161   1              I2C_Start();                                                    //发送起始命令
 162   1              I2C_WriteAbyte(I2C_Write);                      //发送设备地址+写命令
