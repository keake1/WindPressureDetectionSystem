  39          /*************************************
  40          /*函数名称：I2C_WriteAbyte(u8 dat)
  41          /*函数功能：向I2C设备写入一个字节数据
  42          /*输入参数：dat:写入的数据
  43          /*返回值：      无
  44          *************************************/
  45          void I2C_WriteAbyte(u8 dat)
  46          {
  47   1              u8 i;
  48   1              i = 8;
  49   1              do
  50   1              {
  51   2                      if(dat & 0x80)  I2C_SDA = 1;
  52   2                      else            I2C_SDA = 0;
  53   2                      dat <<= 1;
  54   2                      Wait();
C51 COMPILER V9.54   RI2C                                                                  06/30/2025 16:56:32 PAGE 2   

