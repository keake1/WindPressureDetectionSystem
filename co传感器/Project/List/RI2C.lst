 218          u8 IIC_Read_1Byte(u8 SlaveAddress,u8 REG_Address,u8 *REG_data)
 219          {
 220   1          I2C_Start();
 221   1          I2C_WriteAbyte(SlaveAddress<<1);
 222   1          I2C_Check_ACK();
 223   1          I2C_WriteAbyte(REG_Address);
 224   1          I2C_Check_ACK();
 225   1              I2C_Stop();
 226   1          I2C_Start();
 227   1              I2C_WriteAbyte((SlaveAddress<<1)+1);
 228   1          I2C_Check_ACK();
 229   1              *REG_data = I2C_ReadAbyte();
