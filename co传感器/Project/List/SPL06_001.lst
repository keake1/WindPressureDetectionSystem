 467           * @param[in] 
 468           * @param[out] 
 469           * @return     
 470           **********************************************************************/
 471          float spl0601_get_temperature(void)
 472          {
 473   1          float fTCompensate;
 474   1          float fTsc;
C51 COMPILER V9.54   SPL06_001                                                             06/30/2025 16:56:32 PAGE 9   

 475   1      
 476   1          fTsc = spl06.i32rawTemperature / (float)spl06.i32kT;
 477   1          fTCompensate =  spl06_calib_param.c0 * 0.5 + spl06_calib_param.c1 * fTsc;
 478   1          return fTCompensate;
 479   1      }
