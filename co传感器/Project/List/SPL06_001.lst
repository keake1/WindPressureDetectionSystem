 481          /***********************************************************************
 482           * Τχ―ΙΫβΥψ≤ΔΫχ––Έ¬Ε»≤Ι≥Ξ
 483           * @param[in] 
 484           * @param[out] 
 485           * @return     
 486           **********************************************************************/
 487          float spl0601_get_pressure(void)
 488          {
 489   1          float fTsc, fPsc;
 490   1          float qua2, qua3;
 491   1          float fPCompensate;
 492   1      
 493   1          fTsc = spl06.i32rawTemperature / (float)spl06.i32kT;
 494   1          fPsc = spl06.i32rawPressure / (float)spl06.i32kP;
 495   1          qua2 = spl06_calib_param.c10 + fPsc * (spl06_calib_param.c20 + fPsc* spl06_calib_param.c30);
 496   1          qua3 = fTsc * fPsc * (spl06_calib_param.c11 + fPsc * spl06_calib_param.c21);
 497   1                      //qua3 = 0.9f *fTsc * fPsc * (spl06_calib_param.c11 + fPsc * spl06_calib_param.c21);
 498   1              
 499   1          fPCompensate = spl06_calib_param.c00 + fPsc * qua2 + fTsc * spl06_calib_param.c01 + qua3;
 500   1                      //fPCompensate = spl06_calib_param.c00 + fPsc * qua2 + 0.9f *fTsc  * spl06_calib_param.c01 + qua3;
 501   1          return fPCompensate;
 502   1      }
