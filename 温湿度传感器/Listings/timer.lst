line level    source

   1          #include <STC8H.H>
   2          #include "timer.h"
   3          #include "task.h"
   4          
   5          /*
   6           * 定时器0 配置（@24MHz，1T模式，模式0 16位自动重载）
   7           * 重载值 = 65536 - 24000000 / 1000 = 65536 - 24000 = 41536 = 0xA200
   8           * 定时周期：1ms
   9           */
  10          #define TIMER0_RELOAD  0xA200
  11          
  12          /* 各任务计数器定义 */
  13          unsigned int cnt_10ms   = 0;
  14          unsigned int cnt_50ms   = 0;
  15          unsigned int cnt_100ms  = 0;
  16          unsigned int cnt_500ms  = 0;
  17          unsigned int cnt_1000ms = 0;
  18          
  19          /* 定时器0初始化 */
  20          void Timer0_Init(void)
  21          {
  22   1          AUXR |= 0x80;               /* 定时器0 选择 1T 模式（不分频） */
  23   1          TMOD &= 0xF0;               /* 定时器0 工作在模式0（16位自动重载） */
  24   1          TL0 = TIMER0_RELOAD & 0xFF; /* 加载重载值低字节 */
  25   1          TH0 = TIMER0_RELOAD >> 8;   /* 加载重载值高字节 */
  26   1          TF0 = 0;                    /* 清除溢出标志 */
  27   1          ET0 = 1;                    /* 使能定时器0中断 */
  28   1          TR0 = 1;                    /* 启动定时器0 */
  29   1      }
  30          
  31          /* 定时器0中断服务函数（每 1ms 触发一次） */
  32          void Timer0_ISR(void) interrupt 1
  33          {
  34   1          Task_1ms();     /* 1ms 任务：直接在中断中执行，响应最及时 */
  35   1          cnt_10ms++;
  36   1          cnt_50ms++;
  37   1          cnt_100ms++;
  38   1          cnt_500ms++;
  39   1          cnt_1000ms++;
  40   1      }


