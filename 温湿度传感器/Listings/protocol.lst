   7          /*
   8           * Modbus CRC16 计算
   9           * 初始值 0xFFFF，多项式 0xA001（反转多项式 0x8005）
  10           * 结果低字节在前
  11           */
  12          unsigned int CRC16(unsigned char *buf, unsigned char len)
  13          {
  14   1          unsigned int crc = 0xFFFF;
  15   1          unsigned char i, j;
  16   1          for(i = 0; i < len; i++)
  17   1          {
  18   2              crc ^= buf[i];
  19   2              for(j = 0; j < 8; j++)
  20   2              {
  21   3                  if(crc & 0x0001) crc = (crc >> 1) ^ 0xA001;
  22   3                  else             crc >>= 1;
  23   3              }
  24   2          }
  25   1          return crc;   /* 低字节=crc&0xFF，高字节=crc>>8 */
  26   1      }
  27          
  28          /*
  29           * 串口协议处理函数
  30           * 在主循环中轮询调用，收到完整帧后进行解析和回复
  31           */
  32          void Protocol_Process(void)
  33          {
