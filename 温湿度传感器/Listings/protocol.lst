 111   3                   * 应答：原帧回显（8字节）
 112   3                   */
 113   3                  unsigned int reg_addr = (unsigned int)g_uart_rx_buf[2] << 8 | g_uart_rx_buf[3];
 114   3                  unsigned int reg_val  = (unsigned int)g_uart_rx_buf[4] << 8 | g_uart_rx_buf[5];
 115   3      
 116   3                  if(reg_addr == 0x0004)
