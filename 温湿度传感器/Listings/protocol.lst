  42   1          // Uart1_SendBuffer(g_uart_rx_buf, g_uart_rx_len);
  43   1          // /* ---------------------------------------- */
  44   1      
  45   1          /* 判断帧长度是否正确
  46   1           * 注：串口采用超时判帧，g_uart_rx_flag=1时数据已全部收完
  47   1           * 若长度不对说明帧不完整或有干扰，丢弃该帧等待下一帧 */
  48   1          if(g_uart_rx_len != PROTO_RX_LEN)
  49   1          {
  50   2              g_uart_rx_flag = 0;
  51   2              g_uart_rx_len  = 0;
  52   2              return;
  53   2          }
  54   1      
