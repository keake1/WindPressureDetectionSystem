  55   1          /* 判断地址是否匹配 */
  56   1          if(g_uart_rx_buf[0] != g_device_addr)
  57   1          {
  58   2              g_uart_rx_flag = 0;
  59   2              g_uart_rx_len  = 0;
  60   2              return;
  61   2          }
  62   1      
  63   1          /* 验证 CRC16（校验范围：[0]~[5]，共6字节） */
  64   1          crc_calc = CRC16(g_uart_rx_buf, 6);
  65   1          crc_recv = (unsigned int)g_uart_rx_buf[7] << 8 | g_uart_rx_buf[6]; /* 低字节在前 */
  66   1          if(crc_calc != crc_recv)
  67   1          {
  68   2              g_uart_rx_flag = 0;
  69   2              g_uart_rx_len  = 0;
  70   2              return;
  71   2          }
  72   1      
  73   1          /* 根据功能码处理 */
  74   1          switch(g_uart_rx_buf[1])
  75   1          {
  76   2              case PROTO_FUNC_03:
  77   2              {
  78   3                  /*
  79   3                   * 应答帧（9字节）：
  80   3                   *   [0]    设备地址
  81   3                   *   [1]    功能码 0x03
  82   3                   *   [2]    数据字节数 = 4
  83   3                   *   [3]    温度高字节（×10，有符号）
  84   3                   *   [4]    温度低字节
  85   3                   *   [5]    湿度高字节（×10）
  86   3                   *   [6]    湿度低字节
