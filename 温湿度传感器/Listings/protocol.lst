  94   3                  tx_buf[4] = (unsigned char)(g_aht30.temperature & 0xFF);
  95   3                  tx_buf[5] = (unsigned char)((g_aht30.humidity >> 8) & 0xFF);
  96   3                  tx_buf[6] = (unsigned char)(g_aht30.humidity & 0xFF);
  97   3      
