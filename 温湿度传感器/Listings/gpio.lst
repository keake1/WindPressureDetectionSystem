   1          #include <STC8H.H>
   2          #include "gpio.h"
   3          
   4          /*
   5           * STC8H GPIO 模式配置（PxM1 / PxM0）：
   6           *   M1=0  M0=0  ->  准双向口（默认）
   7           *   M1=0  M0=1  ->  推挽输出  ← LED 使用
   8           *   M1=1  M0=0  ->  高阻输入  ← 地址拨码使用
   9           *   M1=1  M0=1  ->  开漏输出
  10           *
  11           * P2.2 推挽输出：P2M1 &= ~0x04; P2M0 |=  0x04;
  12           * P3.4 推挽输出：P3M1 &= ~0x10; P3M0 |=  0x10;
  13           * P0.2 高阻输入：P0M1 |=  0x04; P0M0 &= ~0x04;
  14           * P0.3 高阻输入：P0M1 |=  0x08; P0M0 &= ~0x08;
  15           * P1.2 高阻输入：P1M1 |=  0x04; P1M0 &= ~0x04;
  16           * P1.3 高阻输入：P1M1 |=  0x08; P1M0 &= ~0x08;
  17           * P1.4 高阻输入：P1M1 |=  0x10; P1M0 &= ~0x10;
  18           * P1.5 高阻输入：P1M1 |=  0x20; P1M0 &= ~0x20;
  19           *
  20           * 地址位序（与其他传感器一致）：
  21           *   P1.5 = bit5(最高位), P1.4 = bit4, P1.3 = bit3,
  22           *   P1.2 = bit2, P0.3 = bit1, P0.2 = bit0(最低位)
  23           */
  24          
  25          unsigned char g_device_addr = 0;   /* 设备地址全局变量 */
  26          
  27          void GPIO_Init(void)
  28          {
  29   1          /* ---------- P2.2：绿色 LED，推挽输出，初始熄灭（高电平） ---------- */
  30   1          P2M1 &= ~0x04;
  31   1          P2M0 |=  0x04;
  32   1          LED_GREEN_OFF();
  33   1      
  34   1          /* ---------- P3.4：红色 LED，推挽输出，初始熄灭（高电平） ---------- */
  35   1          P3M1 &= ~0x10;
  36   1          P3M0 |=  0x10;
  37   1          LED_RED_OFF();
  38   1      
  39   1          /* ---------- P0.2、P0.3：地址拨码 bit5、bit4，高阻输入 ---------- */
  40   1          P0M1 |=  0x0C;   /* P0M1[3:2] = 1 */
  41   1          P0M0 &= ~0x0C;   /* P0M0[3:2] = 0 */
  42   1      
  43   1          /* ---------- P1.2~P1.5：地址拨码 bit3~bit0，高阻输入 ---------- */
  44   1          P1M1 |=  0x3C;   /* P1M1[5:2] = 1 */
  45   1          P1M0 &= ~0x3C;   /* P1M0[5:2] = 0 */
  46   1      
  47   1          /* ---------- 使能内部上拉电阻（需先解锁扩展寄存器） ---------- */
  48   1          P_SW2 |= 0x80;   /* EAXFR=1，允许访问 XFR 扩展寄存器 */
  49   1          P0PU  |= 0x0C;   /* P0.2、P0.3 上拉使能 */
  50   1          P1PU  |= 0x3C;   /* P1.2、P1.3、P1.4、P1.5 上拉使能 */
  51   1          P_SW2 &= ~0x80;  /* EAXFR=0，关闭扩展寄存器访问 */
  52   1      }
  53          
  54          /* 翻转绿色 LED（P2.2）电平 */
C51 COMPILER V9.60.7.0   GPIO                                                              06/27/2026 19:48:43 PAGE 2   

  55          void LED_GREEN_Toggle(void)
  56          {
  57   1          P2 ^= 0x04;   /* 对 P2.2 位取反 */
  58   1      }
  59          
  60          /*
  61           * 读取拨码地址
  62           * 引脚低电平 -> 对应位为 1，高电平 -> 对应位为 0
  63           * P1.5 最高位，P0.2 最低位
  64           * 返回值：0 ~ 63
  65           */
  66          unsigned char Read_DeviceAddr(void)
  67          {
  68   1          unsigned char addr = 0;
  69   1      
  70   1          if(!ADDR_BIT5) addr |= 0x20;   /* P1.5 -> bit5 */
  71   1          if(!ADDR_BIT4) addr |= 0x10;   /* P1.4 -> bit4 */
  72   1          if(!ADDR_BIT3) addr |= 0x08;   /* P1.3 -> bit3 */
  73   1          if(!ADDR_BIT2) addr |= 0x04;   /* P1.2 -> bit2 */
  74   1          if(!ADDR_BIT1) addr |= 0x02;   /* P0.3 -> bit1 */
  75   1          if(!ADDR_BIT0) addr |= 0x01;   /* P0.2 -> bit0 */
  76   1      
  77   1          return addr;
  78   1      }


