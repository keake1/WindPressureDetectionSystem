# 默认所有文本文件使用 LF
* text=auto eol=lf

# 明确指定常见文本文件
*.c     text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.hpp   text eol=lf
*.s     text eol=lf
*.ld    text eol=lf
*.cmake text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.ioc   text eol=lf
*.clangd text eol=lf

# 二进制文件不做转换
*.a     binary
*.o     binary
*.elf   binary
*.bin   binary
*.hex   binary
